csh:Class_hasOutcome_PropertyShape
        rdf:type        sh:PropertyShape;
        sh:class        cids:Outcome;
        sh:name         "hasOutcome";
        sh:nodeKind     sh:IRI;
        sh:path         cids:hasOutcome;
        csh:activeTier  cids:BasicTier .

